# ─── Stack Docker prod (VM Daytona) — copier en `.env` et remplir ─────────────
# Sur la VM :  cp .env.example .env  &&  nano .env
# NE JAMAIS committer le .env rempli (déjà gitignoré).

# --- PostgreSQL (conteneur db) ---
POSTGRES_DB=inventory
POSTGRES_USER=inventory
POSTGRES_PASSWORD=change-me-strong-password

# --- Django ---
# Générer une clé :  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-django-secret-key
DEBUG=False
# Hôtes autorisés à servir l'API (IP VM, domaine Cloudflare de l'API...)
# Ajoute l'IP PUBLIQUE de la VM Oracle (et le domaine API si tu en as un)
ALLOWED_HOSTS=localhost,127.0.0.1,VOTRE_IP_PUBLIQUE

# Origines du frontend Cloudflare autorisées (CORS) — sans slash final
CORS_ALLOWED_ORIGINS=https://mon-app.pages.dev
# Origines de confiance pour l'admin Django en HTTPS (CSRF)
CSRF_TRUSTED_ORIGINS=https://mon-app.pages.dev

# --- Infra ---
# Répertoire des volumes persistants sur la VM (voir DeployREADME.md)
DATA_DIR=/srv/app/data
# Port de l'API exposé sur la VM
BACKEND_PORT=8000
GUNICORN_WORKERS=2
