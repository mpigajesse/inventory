# ─── Supabase ─────────────────────────────────────────────────────────────────
# VITE_SUPABASE_URL et VITE_SUPABASE_ANON_KEY sont des clés publiques (anon/publishable)
# et peuvent être exposées côté client.
# ATTENTION : VITE_SUPABASE_DB_PASSWORD est un secret serveur — ne PAS le mettre ici.
# Utilisez-le uniquement dans des variables d'environnement serveur (non préfixées VITE_).
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Seuls le cloud_name et l'upload_preset unsigned sont acceptables côté client.
# ATTENTION : VITE_CLOUDINARY_API_KEY et VITE_CLOUDINARY_ROOT_API_KEY sont des
# secrets serveur — ne jamais les préfixer VITE_ (ils seraient exposés dans le bundle).
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=inventory_products_unsigned
# CLOUDINARY_API_KEY=your_api_key          ← côté serveur uniquement (sans VITE_)
# CLOUDINARY_ROOT_API_KEY=your_root_key   ← côté serveur uniquement (sans VITE_)

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME=NAOSERVICES INVENTORY
VITE_APP_ENV=development

# ─── Django Backend ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api
