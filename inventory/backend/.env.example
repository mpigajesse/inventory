# ─── Django Core ──────────────────────────────────────────────────────────────
# Generate a strong key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-strong-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated list of additional allowed hosts (*.vercel.app is always included)
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (use the pooler URL for serverless)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of additional allowed origins (*.vercel.app is always included via regex)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# ─── Cloudinary (media storage) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
